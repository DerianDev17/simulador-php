---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { answerCurrentQuestion, discardCurrentGame, startOrResumeGame } from "@/lib/game";
import { ensureLearnerId } from "@/lib/learner";
import { ensureDefaultSettings } from "@/lib/store";
import { correctOptionSchema } from "@/lib/validation";
import ArrowRight from "@lucide/astro/icons/arrow-right";
import CircleAlert from "@lucide/astro/icons/circle-alert";
import Sun from "@lucide/astro/icons/sun";
import Trash2 from "@lucide/astro/icons/trash-2";

const categoryId = Number(Astro.params.categoryId);
const settings = ensureDefaultSettings();
let message = "";

if (!Number.isInteger(categoryId) || categoryId <= 0) {
  return Astro.redirect("/");
}

const learnerId = ensureLearnerId(Astro.cookies, Astro.request);

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = formData.get("intent");

  if (intent === "discard-active-game") {
    discardCurrentGame(Astro.cookies, learnerId);
    return Astro.redirect(`/jugar/${categoryId}`);
  }

  const parsedAnswer = correctOptionSchema.safeParse(formData.get("answer"));
  const questionId = Number(formData.get("questionId"));
  const answerToken = formData.get("answerToken");

  if (!parsedAnswer.success || !Number.isInteger(questionId) || typeof answerToken !== "string") {
    message = "Selecciona una respuesta para continuar.";
  } else {
    const result = answerCurrentQuestion(Astro.cookies, categoryId, questionId, answerToken, parsedAnswer.data);
    if (result.status === "completed") {
      return Astro.redirect(`/final?game=${encodeURIComponent(result.game.id)}`);
    }
    if (result.status === "next") {
      return Astro.redirect(`/jugar/${categoryId}`);
    }
    message = "La partida ya no esta disponible. Inicia nuevamente.";
  }
}

const state = startOrResumeGame(Astro.cookies, Astro.request, categoryId, settings.questionsPerGame, learnerId);
---

<BaseLayout
  title="Jugar | Eus3 Simulador"
  description="Partida activa del simulador Eus3."
  robots="noindex, nofollow"
>
  <main id="contenido" class="min-h-screen px-3 py-3 sm:px-5 sm:py-5 lg:p-6">
    <div class="alive-card mx-auto max-w-7xl rounded-lg border border-slate-200/80 bg-white/90 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/85">
      <header class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-3 dark:border-white/10 sm:px-5">
        <a href="/" class="flex items-center gap-3">
          <img src="/img/eus-logo.png" alt="Eus3" class="h-10 w-10 rounded-md object-contain" />
          <div>
            <p class="text-xs font-bold text-slate-950 dark:text-white">
              {state.status === "ready" ? state.categoryName : state.status === "active-conflict" ? state.requestedCategoryName : "Simulador"}
            </p>
            <p class="text-[11px] text-slate-500 dark:text-slate-400">
              {state.status === "ready" ? `Pregunta ${state.currentNumber} de ${state.totalQuestions}` : state.status === "active-conflict" ? "Partida activa detectada" : "Semilla Digital"}
            </p>
          </div>
        </a>

        <div class="flex items-center gap-2">
          <button type="button" class="focus-ring grid h-10 w-10 place-items-center rounded-md border border-slate-200 bg-white text-slate-700 shadow-sm dark:border-white/10 dark:bg-slate-900 dark:text-slate-200" data-theme-toggle aria-label="Cambiar tema">
            <Sun size={18} aria-hidden="true" />
          </button>
        </div>
      </header>

      <div class="p-4 sm:p-6 lg:p-8">
        {state.status === "missing-category" && (
          <section class="mx-auto max-w-2xl rounded-lg border border-slate-200 bg-white p-8 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
            <h1 class="text-2xl font-bold text-slate-950 dark:text-white">Categoria no encontrada</h1>
            <a href="/" class="mt-5 inline-flex rounded-md bg-orange-600 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-700">
              Volver
            </a>
          </section>
        )}

        {state.status === "insufficient" && (
          <section class="mx-auto max-w-2xl rounded-lg border border-amber-200 bg-white p-8 text-center shadow-sm dark:border-amber-400/30 dark:bg-slate-900">
            <p class="text-sm font-semibold uppercase text-amber-700 dark:text-amber-200">{state.categoryName}</p>
            <h1 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">Faltan preguntas para jugar</h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">
              Esta categoria tiene {state.availableQuestions} preguntas y necesita {state.requiredQuestions}.
            </p>
            <a href="/" class="mt-5 inline-flex rounded-md bg-orange-600 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-700">
              Elegir otra categoria
            </a>
          </section>
        )}

        {state.status === "active-conflict" && (
          <section class="mx-auto max-w-2xl rounded-lg border border-amber-200 bg-white p-6 shadow-sm dark:border-amber-400/30 dark:bg-slate-900 sm:p-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
              <span class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200">
                <CircleAlert size={24} aria-hidden="true" />
              </span>
              <div class="min-w-0">
                <p class="text-sm font-bold uppercase text-amber-700 dark:text-amber-200">Partida en curso</p>
                <h1 class="mt-2 text-2xl font-bold text-slate-950 dark:text-white">Ya tienes una partida activa</h1>
                <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
                  Tu partida de {state.active.categoryName} va en la pregunta {state.active.currentNumber} de {state.active.totalQuestions}. Para empezar {state.requestedCategoryName}, primero debes descartarla.
                </p>

                <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                  <a href={`/jugar/${state.active.categoryId}`} class="focus-ring inline-flex items-center justify-center gap-2 rounded-md bg-orange-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
                    Continuar {state.active.categoryName}
                    <ArrowRight size={16} aria-hidden="true" />
                  </a>
                  <form method="post">
                    <input type="hidden" name="intent" value="discard-active-game" />
                    <button class="focus-ring inline-flex w-full items-center justify-center gap-2 rounded-md border border-red-200 px-4 py-3 text-sm font-bold text-red-700 hover:bg-red-50 dark:border-red-400/30 dark:text-red-200 dark:hover:bg-red-500/10">
                      <Trash2 size={16} aria-hidden="true" />
                      Descartar y empezar
                    </button>
                  </form>
                </div>

                <a href="/simulacros" class="focus-ring mt-4 inline-flex rounded-md px-1 py-2 text-sm font-bold text-slate-700 hover:text-orange-700 dark:text-slate-200 dark:hover:text-orange-200">
                  Volver a simulacros
                </a>
              </div>
            </div>
          </section>
        )}

        {state.status === "ready" && (
          <>
            <div
              class="mb-5 h-1.5 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800"
              role="progressbar"
              aria-label="Progreso del juego"
              aria-valuemin="1"
              aria-valuemax={state.totalQuestions}
              aria-valuenow={state.currentNumber}
            >
              <div class="h-full rounded-md bg-orange-600 transition-[width] duration-500 motion-reduce:transition-none" style={`width: ${(state.currentNumber / state.totalQuestions) * 100}%`}></div>
            </div>

            {message && <p class="mb-4 rounded-md bg-red-50 px-3 py-2 text-sm text-red-700 dark:bg-red-500/15 dark:text-red-200" role="alert" aria-live="assertive">{message}</p>}

            <section class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_260px]">
              <article class="alive-card motion-reveal rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900 sm:p-7">
                <p class="mb-3 inline-flex items-center gap-2 rounded-md bg-orange-50 px-2.5 py-1 text-xs font-black uppercase text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
                  <span class="pulse-dot" aria-hidden="true"></span>
                  Pregunta activa
                </p>
                <h1 class="text-xl font-bold leading-8 text-slate-950 dark:text-white">{state.question.prompt}</h1>
                {state.question.imagePath && (
                  <div class="mt-5 grid min-h-44 place-items-center rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-white/10 dark:bg-slate-950">
                    <img src={state.question.imagePath} alt={`Imagen de apoyo para la pregunta: ${state.question.prompt}`} class="max-h-64 w-full rounded-md object-contain" />
                  </div>
                )}

                <form method="post" class="mt-6 space-y-3">
                  <input type="hidden" name="questionId" value={state.question.id} />
                  <input type="hidden" name="answerToken" value={state.answerToken} />
                  <fieldset class="space-y-3">
                    <legend class="sr-only">Opciones de respuesta</legend>
                    {[
                      ["A", state.question.optionA],
                      ["B", state.question.optionB],
                      ["C", state.question.optionC],
                      ["D", state.question.optionD]
                    ].map(([value, label]) => (
                      <label class="alive-card flex min-h-14 cursor-pointer items-center gap-3 rounded-md border border-slate-200 bg-white p-3 transition hover:border-emerald-300 hover:bg-emerald-50 has-checked:border-emerald-500 has-checked:bg-emerald-50 dark:border-white/10 dark:bg-slate-950 dark:hover:border-emerald-400/50 dark:hover:bg-emerald-500/10 dark:has-checked:border-emerald-400 dark:has-checked:bg-emerald-500/10">
                        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-md bg-slate-100 text-sm font-bold text-slate-700 dark:bg-slate-800 dark:text-slate-200">{value}</span>
                        <span class="min-w-0 flex-1 font-semibold leading-5 text-slate-800 dark:text-slate-100">{label}</span>
                        <input class="h-5 w-5 shrink-0 accent-emerald-600" type="radio" name="answer" value={value} required />
                      </label>
                    ))}
                  </fieldset>

                  <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-between">
                    <a href="/categorias" class="focus-ring inline-flex justify-center rounded-md border border-slate-200 px-4 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10">Salir a categorias</a>
                    <button class="focus-ring rounded-md bg-orange-600 px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
                      Siguiente
                    </button>
                  </div>
                </form>
              </article>

              <aside class="alive-card motion-reveal rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900" style="--reveal-delay: 80ms">
                <h2 class="font-bold text-slate-950 dark:text-white">Navegacion</h2>
                <div class="mt-4 grid grid-cols-4 gap-2">
                  {Array.from({ length: state.totalQuestions }, (_, index) => {
                    const number = index + 1;
                    const current = number === state.currentNumber;
                    const answered = number < state.currentNumber;
                    return (
                      <span class:list={[
                        "grid h-9 w-9 place-items-center rounded-md text-sm font-bold",
                        current
                          ? "bg-orange-600 text-white"
                          : answered
                            ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-500/20 dark:text-emerald-200"
                            : "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300"
                      ]}>
                        {number}
                      </span>
                    );
                  })}
                </div>
                <div class="mt-5 space-y-2 text-xs text-slate-600 dark:text-slate-400">
                  <p><span class="mr-2 inline-block h-3 w-3 rounded bg-emerald-300"></span>Respondidas</p>
                  <p><span class="mr-2 inline-block h-3 w-3 rounded bg-orange-600"></span>Actual</p>
                  <p><span class="mr-2 inline-block h-3 w-3 rounded bg-slate-200 dark:bg-slate-700"></span>Sin responder</p>
                </div>
              </aside>
            </section>
          </>
        )}
      </div>
    </div>
  </main>
</BaseLayout>
