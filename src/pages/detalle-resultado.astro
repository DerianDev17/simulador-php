---
import PublicSidebar from "@/components/PublicSidebar.astro";
import PublicMobileNav from "@/components/PublicMobileNav.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAdminSession } from "@/lib/auth";
import { gameSessionCookie, getGameDetails, type GameDetailQuestion } from "@/lib/game";
import { ensureLearnerId } from "@/lib/learner";
import ArrowLeft from "@lucide/astro/icons/arrow-left";
import CircleCheck from "@lucide/astro/icons/circle-check";
import CircleX from "@lucide/astro/icons/circle-x";
import RotateCcw from "@lucide/astro/icons/rotate-ccw";
import Target from "@lucide/astro/icons/target";

const learnerId = ensureLearnerId(Astro.cookies, Astro.request);
const adminSession = getAdminSession(Astro.cookies);
Astro.response.headers.set("Cache-Control", "no-store");

const gameId = Astro.url.searchParams.get("game") ?? Astro.cookies.get(gameSessionCookie)?.value;
const detail = getGameDetails(gameId, adminSession ? undefined : learnerId);

if (detail.status === "incomplete") {
  return Astro.redirect(`/jugar/${detail.categoryId}`);
}

const optionRows = (answer: GameDetailQuestion) =>
  [
    { key: "A", label: answer.question.optionA },
    { key: "B", label: answer.question.optionB },
    { key: "C", label: answer.question.optionC },
    { key: "D", label: answer.question.optionD }
  ] as const;
---

<BaseLayout
  title="Detalle del resultado | Semilla Digital"
  description="Detalle privado de respuestas de un simulacro completado en Semilla Digital."
  robots="noindex, nofollow"
>
  <main id="contenido" class="min-h-screen px-3 pb-[calc(6rem+env(safe-area-inset-bottom))] pt-3 sm:px-5 sm:pt-5 lg:p-6">
    <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
      <PublicSidebar active="simulations" />

      <section class="min-w-0 rounded-lg border border-slate-200/80 bg-white/90 p-4 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/82 sm:p-6 lg:p-8">
        {detail.status === "not-found" ? (
          <div class="mx-auto max-w-xl rounded-lg border border-slate-200 bg-white p-8 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
            <h1 class="text-2xl font-bold text-slate-950 dark:text-white">No hay detalle disponible</h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Completa un simulacro para revisar cada respuesta.</p>
            <a href="/simulacros" class="focus-ring mt-7 inline-flex rounded-md bg-orange-600 px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
              Ir a simulacros
            </a>
          </div>
        ) : (
          <section class="space-y-6">
            <div class="flex flex-col justify-between gap-4 xl:flex-row xl:items-end">
              <div>
                <p class="text-sm font-bold text-orange-700 dark:text-orange-200">Revision completa</p>
                <h1 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white sm:text-3xl">Detalle del simulacro</h1>
                <p class="mt-2 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
                  {detail.categoryName}: revisa tus {detail.totalQuestions} respuestas y compara tu seleccion con la opcion correcta.
                </p>
              </div>

              <div class="flex flex-col gap-2 sm:flex-row">
                <a href={`/final?game=${encodeURIComponent(detail.game.id)}`} class="focus-ring inline-flex items-center justify-center gap-2 rounded-md border border-slate-200 px-4 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10">
                  <ArrowLeft size={16} aria-hidden="true" />
                  Volver al resultado
                </a>
                {detail.incorrect > 0 && (
                  <a href={`/repasar-errores?game=${encodeURIComponent(detail.game.id)}`} class="focus-ring inline-flex items-center justify-center gap-2 rounded-md border border-orange-200 px-4 py-3 text-sm font-bold text-orange-700 hover:bg-orange-50 dark:border-orange-400/30 dark:text-orange-200 dark:hover:bg-orange-500/10">
                    <RotateCcw size={16} aria-hidden="true" />
                    Repasar errores
                  </a>
                )}
              </div>
            </div>

            <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
              {[
                { label: "Puntaje", value: `${detail.score}%`, help: "Resultado final", icon: Target, tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200" },
                { label: "Correctas", value: detail.correct, help: "Respuestas acertadas", icon: CircleCheck, tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200" },
                { label: "Incorrectas", value: detail.incorrect, help: "Para revisar", icon: CircleX, tone: "bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-200" },
                { label: "Preguntas", value: detail.totalQuestions, help: detail.categoryName, icon: Target, tone: "bg-slate-100 text-slate-700 dark:bg-white/10 dark:text-slate-200" }
              ].map((metric) => {
                const Icon = metric.icon;
                return (
                  <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{metric.label}</p>
                        <p class="mt-2 truncate text-2xl font-black text-slate-950 dark:text-white">{metric.value}</p>
                      </div>
                      <span class:list={["grid h-10 w-10 shrink-0 place-items-center rounded-md", metric.tone]}>
                        <Icon size={20} aria-hidden="true" />
                      </span>
                    </div>
                    <p class="mt-3 truncate text-xs text-slate-600 dark:text-slate-400">{metric.help}</p>
                  </article>
                );
              })}
            </section>

            {detail.answers.length === 0 ? (
              <article class="rounded-lg border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h2 class="text-xl font-bold text-slate-950 dark:text-white">Esta partida no tiene respuestas registradas</h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                  Los detalles completos se guardan para los simulacros completados con la version actual.
                </p>
                <a href={`/jugar/${detail.game.categoryId}`} class="focus-ring mt-6 inline-flex items-center justify-center rounded-md bg-orange-600 px-5 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
                  Nuevo intento
                </a>
              </article>
            ) : (
              <section class="space-y-4">
                {detail.answers.map((answer) => (
                  <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900" data-testid="result-detail-card">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                      <div class="min-w-0">
                        <p class="text-xs font-bold uppercase text-orange-700 dark:text-orange-200">Pregunta {answer.order}</p>
                        <h2 class="mt-2 text-lg font-bold leading-7 text-slate-950 dark:text-white">{answer.question.prompt}</h2>
                      </div>
                      <span
                        class:list={[
                          "inline-flex w-fit items-center gap-2 rounded-md px-3 py-2 text-sm font-bold",
                          answer.isCorrect
                            ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                            : "bg-red-50 text-red-700 dark:bg-red-500/15 dark:text-red-200"
                        ]}
                      >
                        {answer.isCorrect ? <CircleCheck size={16} aria-hidden="true" /> : <CircleX size={16} aria-hidden="true" />}
                        {answer.isCorrect ? "Correcta" : "Incorrecta"}
                      </span>
                    </div>

                    {answer.question.imagePath && (
                      <div class="mt-5 grid min-h-40 place-items-center rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-white/10 dark:bg-slate-950">
                        <img src={answer.question.imagePath} alt={`Imagen de apoyo para la pregunta: ${answer.question.prompt}`} class="max-h-56 w-full rounded-md object-contain" />
                      </div>
                    )}

                    <div class="mt-5 grid gap-3 lg:grid-cols-2">
                      <div
                        class:list={[
                          "rounded-lg border p-4",
                          answer.isCorrect
                            ? "border-emerald-200 bg-emerald-50 dark:border-emerald-400/30 dark:bg-emerald-500/10"
                            : "border-red-200 bg-red-50 dark:border-red-400/30 dark:bg-red-500/10"
                        ]}
                      >
                        <p
                          class:list={[
                            "text-xs font-bold uppercase",
                            answer.isCorrect ? "text-emerald-700 dark:text-emerald-200" : "text-red-700 dark:text-red-200"
                          ]}
                        >
                          Tu respuesta
                        </p>
                        <p
                          class:list={[
                            "mt-2 text-base font-bold",
                            answer.isCorrect ? "text-emerald-950 dark:text-emerald-100" : "text-red-950 dark:text-red-100"
                          ]}
                        >
                          {answer.selectedOption}. {answer.selectedLabel}
                        </p>
                      </div>

                      <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 dark:border-emerald-400/30 dark:bg-emerald-500/10">
                        <p class="text-xs font-bold uppercase text-emerald-700 dark:text-emerald-200">Respuesta correcta</p>
                        <p class="mt-2 text-base font-bold text-emerald-950 dark:text-emerald-100">
                          {answer.correctOption}. {answer.correctLabel}
                        </p>
                      </div>
                    </div>

                    <div class="mt-5 grid gap-2">
                      {optionRows(answer).map((option) => {
                        const isSelected = option.key === answer.selectedOption;
                        const isCorrect = option.key === answer.correctOption;
                        return (
                          <div
                            class:list={[
                              "flex min-w-0 items-center gap-3 rounded-md border p-3 text-sm",
                              isCorrect
                                ? "border-emerald-200 bg-emerald-50 text-emerald-950 dark:border-emerald-400/30 dark:bg-emerald-500/10 dark:text-emerald-100"
                                : isSelected
                                  ? "border-red-200 bg-red-50 text-red-950 dark:border-red-400/30 dark:bg-red-500/10 dark:text-red-100"
                                  : "border-slate-200 bg-slate-50 text-slate-700 dark:border-white/10 dark:bg-slate-950 dark:text-slate-300"
                            ]}
                          >
                            <span
                              class:list={[
                                "grid h-8 w-8 shrink-0 place-items-center rounded-md text-xs font-black",
                                isCorrect
                                  ? "bg-emerald-600 text-white"
                                  : isSelected
                                    ? "bg-red-600 text-white"
                                    : "bg-white text-slate-700 shadow-sm dark:bg-white/10 dark:text-slate-200"
                              ]}
                            >
                              {option.key}
                            </span>
                            <span class="min-w-0 flex-1 break-words font-semibold">{option.label}</span>
                            {isCorrect ? (
                              <span class="hidden rounded-md bg-white px-2 py-1 text-xs font-bold text-emerald-700 shadow-sm dark:bg-emerald-500/15 dark:text-emerald-100 sm:inline-flex">
                                Correcta
                              </span>
                            ) : isSelected ? (
                              <span class="hidden rounded-md bg-white px-2 py-1 text-xs font-bold text-red-700 shadow-sm dark:bg-red-500/15 dark:text-red-100 sm:inline-flex">
                                Marcada
                              </span>
                            ) : null}
                          </div>
                        );
                      })}
                    </div>
                  </article>
                ))}
              </section>
            )}
          </section>
        )}
      </section>
    </div>
    <PublicMobileNav active="simulations" />
  </main>
</BaseLayout>
