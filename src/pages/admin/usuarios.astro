---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAdminSession } from "@/lib/auth";
import { ensureDefaultSettings } from "@/lib/store";
import Info from "@lucide/astro/icons/info";
import ShieldCheck from "@lucide/astro/icons/shield-check";
import User from "@lucide/astro/icons/user";

const session = getAdminSession(Astro.cookies);
if (!session) {
  return Astro.redirect("/admin/login");
}

const settings = ensureDefaultSettings();
---

<AdminLayout title="Usuarios" active="users" csrfToken={session.csrfToken}>
  <section class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-950 dark:text-white sm:text-3xl">Usuarios</h1>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Acceso administrativo configurado para el simulador.</p>
    </div>

    <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_320px]">
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-4">
            <span class="grid h-14 w-14 place-items-center rounded-lg bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
              <User size={26} aria-hidden="true" />
            </span>
            <div>
              <h2 class="text-lg font-bold text-slate-950 dark:text-white">{settings.adminUsername}</h2>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Administrador principal</p>
            </div>
          </div>
          <a href="/admin/configuracion" class="focus-ring inline-flex w-fit rounded-md bg-orange-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
            Editar acceso
          </a>
        </div>
      </article>

      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
        <div class="flex items-start gap-3">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200">
            <ShieldCheck size={20} aria-hidden="true" />
          </span>
          <div>
            <h2 class="font-bold text-slate-950 dark:text-white">Sesion protegida</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600 dark:text-slate-400">Las rutas administrativas requieren login y token de sesion.</p>
          </div>
        </div>
      </article>
    </section>

    <section class="rounded-lg border border-sky-200 bg-sky-50 p-5 text-sky-950 dark:border-sky-400/30 dark:bg-sky-500/15 dark:text-sky-100">
      <div class="flex items-start gap-3">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-md bg-white/70 text-sky-700 dark:bg-white/10 dark:text-sky-200">
          <Info size={20} aria-hidden="true" />
        </span>
        <div>
          <h2 class="font-bold">Modo de usuarios actual</h2>
          <p class="mt-1 text-sm leading-6">
            El sistema usa un unico administrador. El progreso publico se separa por visitante anonimo mediante cookie, pero no existe multiusuario real ni perfiles de estudiantes.
          </p>
        </div>
      </div>
    </section>
  </section>
</AdminLayout>
