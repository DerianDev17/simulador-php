---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAdminSession } from "@/lib/auth";
import { ensureDefaultSettings, getQuizReportSummary, getTotalQuestions, listCategorySummaries } from "@/lib/store";
import ClipboardList from "@lucide/astro/icons/clipboard-list";
import CircleGauge from "@lucide/astro/icons/circle-gauge";
import Sparkles from "@lucide/astro/icons/sparkles";
import Target from "@lucide/astro/icons/target";
import Trophy from "@lucide/astro/icons/trophy";

const session = getAdminSession(Astro.cookies);
if (!session) {
  return Astro.redirect("/admin/login");
}

const report = getQuizReportSummary();
const categories = listCategorySummaries();
const settings = ensureDefaultSettings();
const totalQuestions = getTotalQuestions();
const progressPercent = report.totalAttempts > 0 ? report.averageScore : 0;
const progressDegrees = Math.round((progressPercent / 100) * 360);
---

<AdminLayout title="Panel" active="dashboard" csrfToken={session.csrfToken}>
  <section class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-950 dark:text-white sm:text-3xl">Hola, administrador!</h1>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Preparate hoy para mantener el simulador listo.</p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      {[
        { label: "Preguntas respondidas", value: report.totalAnswered, help: "En intentos completados", icon: ClipboardList, tone: "text-orange-700 bg-orange-50 dark:text-orange-200 dark:bg-orange-500/15" },
        { label: "Aciertos", value: report.totalCorrect, help: `${report.averageScore}% precision media`, icon: Target, tone: "text-emerald-700 bg-emerald-50 dark:text-emerald-200 dark:bg-emerald-500/15" },
        { label: "Simulacros realizados", value: report.totalAttempts, help: `${report.completedToday} hoy`, icon: CircleGauge, tone: "text-violet-700 bg-violet-50 dark:text-violet-200 dark:bg-violet-500/15" },
        { label: "Banco actual", value: totalQuestions, help: "Preguntas activas", icon: Sparkles, tone: "text-amber-700 bg-amber-50 dark:text-amber-200 dark:bg-amber-500/15" }
      ].map((metric) => {
        const Icon = metric.icon;
        return (
          <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
            <div class="flex items-start justify-between gap-3">
              <span class:list={["grid h-9 w-9 place-items-center rounded-md", metric.tone]}>
                <Icon size={18} aria-hidden="true" />
              </span>
              <p class="text-right text-2xl font-bold text-slate-950 dark:text-white">{metric.value}</p>
            </div>
            <p class="mt-3 text-sm font-bold text-slate-800 dark:text-slate-100">{metric.label}</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">{metric.help}</p>
          </article>
        );
      })}
    </div>

    <section class="grid gap-4 xl:grid-cols-[minmax(0,1.25fr)_380px]">
      <article class="overflow-hidden rounded-lg border border-orange-500/20 bg-orange-600 text-white shadow-lg shadow-orange-900/10">
        <div class="relative min-h-56 bg-[linear-gradient(90deg,rgba(234,88,12,0.98),rgba(249,115,22,0.82)),url('/img/fondoNaranja.jpg')] bg-cover bg-center p-6">
          <div class="relative z-10 max-w-md">
            <p class="text-xs font-bold uppercase text-orange-100">Practica por categoria</p>
            <h2 class="mt-4 text-3xl font-bold leading-tight">Pon a prueba tus conocimientos</h2>
            <p class="mt-3 text-sm leading-6 text-orange-50">Administra categorias y preguntas para mantener el banco actualizado.</p>
            <a href="/admin/preguntas/nueva" class="focus-ring mt-5 inline-flex rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm hover:bg-orange-50">
              Nueva pregunta
            </a>
          </div>
          <Trophy size={118} class="absolute bottom-5 right-5 text-orange-200/70" aria-hidden="true" />
        </div>
      </article>

      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
        <h2 class="text-base font-bold text-slate-950 dark:text-white">Tu progreso general</h2>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Resumen de actividad del simulador.</p>

        <div class="mt-5 grid grid-cols-[120px_1fr] items-center gap-5">
          <div class="grid h-28 w-28 place-items-center rounded-full" style={`background: conic-gradient(#f97316 ${progressDegrees}deg, #e2e8f0 0deg);`}>
            <div class="grid h-20 w-20 place-items-center rounded-full bg-white text-center shadow-inner dark:bg-slate-900">
              <div>
                <p class="text-2xl font-bold text-slate-950 dark:text-white">{progressPercent}%</p>
                <p class="text-[11px] font-semibold text-slate-500 dark:text-slate-400">Completado</p>
              </div>
            </div>
          </div>
          <div class="space-y-3">
            <div>
              <p class="text-lg font-bold text-slate-950 dark:text-white">{categories.length}</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Categorias</p>
            </div>
            <div>
              <p class="text-lg font-bold text-slate-950 dark:text-white">{totalQuestions}</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Preguntas</p>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
      <h2 class="text-lg font-bold text-slate-950 dark:text-white">Preguntas por categoria</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category, index) => {
          const ready = category.questionCount >= settings.questionsPerGame;
          return (
            <div class="rounded-lg border border-slate-200 p-4 dark:border-white/10">
              <div class="flex items-start justify-between">
                <span class="grid h-9 w-9 place-items-center rounded-md bg-orange-50 text-xs font-bold text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <span class:list={[
                  "rounded-md px-2 py-1 text-[11px] font-bold",
                  ready
                    ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                    : "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
                ]}>
                  {ready ? "Lista" : "Incompleta"}
                </span>
              </div>
              <p class="mt-3 font-bold text-slate-900 dark:text-white">{category.name}</p>
              <p class="text-sm text-slate-600 dark:text-slate-400">{category.questionCount} preguntas</p>
            </div>
          );
        })}
      </div>
    </section>
  </section>
</AdminLayout>
