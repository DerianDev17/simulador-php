---
import PublicMobileNav from "@/components/PublicMobileNav.astro";
import PublicSidebar from "@/components/PublicSidebar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ensureLearnerId } from "@/lib/learner";
import { getQuizReportSummary, listCategoryAttemptSummaries, listRecentQuizAttempts } from "@/lib/store";
import CalendarDays from "@lucide/astro/icons/calendar-days";
import ChartColumn from "@lucide/astro/icons/chart-column";
import CircleCheck from "@lucide/astro/icons/circle-check";
import Clock3 from "@lucide/astro/icons/clock-3";
import History from "@lucide/astro/icons/history";
import RotateCcw from "@lucide/astro/icons/rotate-ccw";
import Target from "@lucide/astro/icons/target";
import Trophy from "@lucide/astro/icons/trophy";

const learnerId = ensureLearnerId(Astro.cookies, Astro.request);
Astro.response.headers.set("Cache-Control", "no-store");

const report = getQuizReportSummary(learnerId);
const attempts = listRecentQuizAttempts(24, learnerId);
const categoryAttempts = listCategoryAttemptSummaries(learnerId);

const formatDuration = (seconds: number) => {
  const minutes = Math.floor(seconds / 60);
  const remainingSeconds = seconds % 60;
  return `${minutes}:${String(remainingSeconds).padStart(2, "0")}`;
};

const formatDate = (value: string) =>
  new Intl.DateTimeFormat("es", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(new Date(value));

const summaryCards = [
  {
    label: "Intentos",
    value: report.totalAttempts,
    help: `${report.completedToday} completados hoy`,
    icon: Trophy,
    tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200"
  },
  {
    label: "Precision media",
    value: `${report.averageScore}%`,
    help: `${report.totalCorrect}/${report.totalAnswered} correctas`,
    icon: Target,
    tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
  },
  {
    label: "Tiempo medio",
    value: formatDuration(report.averageDurationSeconds),
    help: "Por intento completado",
    icon: Clock3,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200"
  },
  {
    label: "Categorias",
    value: categoryAttempts.length,
    help: "Con intentos registrados",
    icon: ChartColumn,
    tone: "bg-rose-50 text-rose-700 dark:bg-rose-500/15 dark:text-rose-200"
  }
];
---

<BaseLayout
  title="Historial | Eus3 Simulador"
  description="Historial privado de intentos completados, precision y categorias practicadas en Eus3."
  robots="noindex, nofollow"
>
  <main id="contenido" class="min-h-screen px-3 pb-[calc(6rem+env(safe-area-inset-bottom))] pt-3 sm:px-5 sm:pt-5 lg:p-6">
    <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
      <PublicSidebar active="history" />

      <section class="min-w-0 rounded-lg border border-slate-200/80 bg-white/90 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/84">
        <header class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-3 dark:border-white/10 sm:px-5">
          <a href="/" class="flex min-w-0 items-center gap-3 lg:hidden">
            <img src="/img/eus-logo.png" alt="Eus3" class="h-10 w-10 rounded-md object-contain" />
            <div class="min-w-0">
              <p class="text-[10px] font-bold uppercase text-orange-600 dark:text-orange-300">Simulador</p>
              <p class="truncate text-sm font-bold text-slate-950 dark:text-white">EUS3 Preuniversitario</p>
            </div>
          </a>

          <div class="hidden lg:block">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">Progreso</p>
            <p class="text-sm font-bold text-slate-950 dark:text-white">Historial</p>
          </div>

          <a href="/simulacros" class="focus-ring ml-auto inline-flex items-center gap-2 rounded-md bg-orange-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
            <RotateCcw size={16} aria-hidden="true" />
            Nuevo intento
          </a>
        </header>

        <div class="p-4 sm:p-6 lg:p-8">
          <section class="mb-6 flex flex-col justify-between gap-3 xl:flex-row xl:items-end">
            <div>
              <p class="inline-flex items-center gap-2 text-sm font-bold text-orange-700 dark:text-orange-200">
                <History size={16} aria-hidden="true" />
                Historial de practica
              </p>
              <h1 class="mt-2 text-2xl font-bold leading-tight text-slate-950 dark:text-white sm:text-3xl">
                Revisa tus intentos completados
              </h1>
              <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600 dark:text-slate-400">
                Usa tus resultados anteriores para detectar categorias fuertes, puntos a reforzar y el ritmo real de cada practica.
              </p>
            </div>
          </section>

          <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {summaryCards.map((card) => {
              const Icon = card.icon;
              return (
                <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{card.label}</p>
                      <p class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{card.value}</p>
                    </div>
                    <span class:list={["grid h-10 w-10 place-items-center rounded-md", card.tone]}>
                      <Icon size={20} aria-hidden="true" />
                    </span>
                  </div>
                  <p class="mt-3 text-xs text-slate-600 dark:text-slate-400">{card.help}</p>
                </article>
              );
            })}
          </section>

          <section class="mt-6 grid gap-4 xl:grid-cols-[minmax(0,1fr)_340px]">
            <article class="min-w-0 rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
              <div class="mb-4 flex flex-col justify-between gap-2 sm:flex-row sm:items-end">
                <div>
                  <h2 class="text-lg font-bold text-slate-950 dark:text-white">Intentos recientes</h2>
                  <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Ultimos {attempts.length} simulacros completados.</p>
                </div>
              </div>

              {attempts.length === 0 ? (
                <div class="rounded-lg border border-dashed border-slate-300 p-8 text-center dark:border-white/10">
                  <CircleCheck size={34} class="mx-auto text-orange-600 dark:text-orange-300" aria-hidden="true" />
                  <h3 class="mt-3 text-lg font-bold text-slate-950 dark:text-white">Aun no hay intentos</h3>
                  <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Completa un simulacro para empezar a construir tu historial.</p>
                  <a href="/simulacros" class="focus-ring mt-5 inline-flex rounded-md bg-orange-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
                    Ir a simulacros
                  </a>
                </div>
              ) : (
                <div class="overflow-x-auto">
                  <table class="w-full min-w-[720px] text-left text-sm">
                    <thead class="text-xs uppercase text-slate-500 dark:text-slate-400">
                      <tr class="border-b border-slate-100 dark:border-white/10">
                        <th scope="col" class="px-3 py-3 font-bold">Fecha</th>
                        <th scope="col" class="px-3 py-3 font-bold">Categoria</th>
                        <th scope="col" class="px-3 py-3 font-bold">Resultado</th>
                        <th scope="col" class="px-3 py-3 font-bold">Tiempo</th>
                        <th scope="col" class="px-3 py-3 text-right font-bold">Detalle</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-white/10">
                      {attempts.map((attempt) => (
                        <tr class="align-top hover:bg-slate-50 dark:hover:bg-white/5">
                          <td class="px-3 py-3 text-slate-600 dark:text-slate-300">
                            <span class="inline-flex items-center gap-2">
                              <CalendarDays size={15} aria-hidden="true" />
                              {formatDate(attempt.finishedAt)}
                            </span>
                          </td>
                          <td class="px-3 py-3 font-bold text-slate-950 dark:text-white">{attempt.categoryName}</td>
                          <td class="px-3 py-3">
                            <span class="rounded-md bg-orange-50 px-2.5 py-1 text-xs font-black text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
                              {attempt.score}%
                            </span>
                            <span class="ml-2 text-slate-500 dark:text-slate-400">
                              {attempt.correctCount}/{attempt.totalQuestions}
                            </span>
                          </td>
                          <td class="px-3 py-3 text-slate-600 dark:text-slate-300">{formatDuration(attempt.durationSeconds)}</td>
                          <td class="px-3 py-3 text-right">
                            <a href={`/final?game=${encodeURIComponent(attempt.id)}`} class="focus-ring inline-flex rounded-md border border-slate-200 px-3 py-2 text-sm font-bold text-slate-700 hover:border-orange-200 hover:text-orange-700 dark:border-white/10 dark:text-slate-200 dark:hover:text-orange-200">
                              Ver resultado
                            </a>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </article>

            <aside class="space-y-4">
              <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h2 class="text-base font-bold text-slate-950 dark:text-white">Lectura rapida</h2>
                <dl class="mt-4 space-y-3 text-sm">
                  <div>
                    <dt class="text-slate-500 dark:text-slate-400">Mejor categoria</dt>
                    <dd class="font-bold text-slate-950 dark:text-white">
                      {report.bestCategoryName ? `${report.bestCategoryName} (${report.bestCategoryScore}%)` : "Sin datos"}
                    </dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 dark:text-slate-400">Categoria a reforzar</dt>
                    <dd class="font-bold text-slate-950 dark:text-white">
                      {report.weakestCategoryName ? `${report.weakestCategoryName} (${report.weakestCategoryScore}%)` : "Sin datos"}
                    </dd>
                  </div>
                </dl>
              </article>

              <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h2 class="text-base font-bold text-slate-950 dark:text-white">Por categoria</h2>
                {categoryAttempts.length === 0 ? (
                  <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">Completa intentos para ver promedios por categoria.</p>
                ) : (
                  <div class="mt-4 space-y-3">
                    {categoryAttempts.slice(0, 6).map((category) => (
                      <div class="rounded-md border border-slate-200 p-3 dark:border-white/10">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <p class="font-bold text-slate-950 dark:text-white">{category.categoryName}</p>
                            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{category.attempts} intentos</p>
                          </div>
                          <span class="rounded-md bg-slate-100 px-2 py-1 text-xs font-black text-slate-700 dark:bg-white/10 dark:text-slate-200">
                            {category.averageScore}%
                          </span>
                        </div>
                        <div class="mt-3 h-2 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800">
                          <div class="h-full rounded-md bg-orange-600" style={`width: ${category.averageScore}%`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </article>
            </aside>
          </section>
        </div>
      </section>
    </div>

    <PublicMobileNav active="history" />
  </main>
</BaseLayout>
