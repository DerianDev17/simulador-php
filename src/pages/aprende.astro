---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicMobileNav from "@/components/PublicMobileNav.astro";
import PublicSidebar from "@/components/PublicSidebar.astro";
import { gameSessionCookie, getGameResult } from "@/lib/game";
import { ensureLearnerId } from "@/lib/learner";
import {
  ensureDefaultSettings,
  getCategory,
  getQuizReportSummary,
  listCategoryAttemptSummaries,
  listCategorySummaries
} from "@/lib/store";
import BookCheck from "@lucide/astro/icons/book-check";
import BookOpen from "@lucide/astro/icons/book-open";
import ChevronRight from "@lucide/astro/icons/chevron-right";
import CircleCheck from "@lucide/astro/icons/circle-check";
import Clock3 from "@lucide/astro/icons/clock-3";
import ListChecks from "@lucide/astro/icons/list-checks";
import Moon from "@lucide/astro/icons/moon";
import Play from "@lucide/astro/icons/play";
import RotateCcw from "@lucide/astro/icons/rotate-ccw";
import Sun from "@lucide/astro/icons/sun";
import Target from "@lucide/astro/icons/target";
import Trophy from "@lucide/astro/icons/trophy";

const settings = ensureDefaultSettings();
const learnerId = ensureLearnerId(Astro.cookies, Astro.request);
const report = getQuizReportSummary(learnerId);
const categories = listCategorySummaries();
const categoryAttempts = listCategoryAttemptSummaries(learnerId);
const attemptByCategory = new Map(categoryAttempts.map((attempt) => [attempt.categoryId, attempt]));
const readyCategories = categories.filter((category) => category.questionCount >= settings.questionsPerGame);
const firstReadyCategory = readyCategories[0];
const currentGame = getGameResult(Astro.cookies.get(gameSessionCookie)?.value, learnerId);
const activeCategory = currentGame.status === "incomplete" ? getCategory(currentGame.categoryId) : undefined;
const totalQuestions = categories.reduce((total, category) => total + category.questionCount, 0);
const bankMinimum = Math.max(categories.length * settings.questionsPerGame, 1);
const bankCoverage = categories.length > 0 ? Math.min(100, Math.round((totalQuestions * 100) / bankMinimum)) : 0;
const averageMinutes = report.averageDurationSeconds > 0 ? `${Math.max(1, Math.round(report.averageDurationSeconds / 60))} min` : "Sin datos";

const primaryHref = activeCategory
  ? `/jugar/${activeCategory.id}`
  : firstReadyCategory
    ? `/jugar/${firstReadyCategory.id}`
    : "/categorias";

const primaryLabel = activeCategory
  ? `Continuar ${activeCategory.name}`
  : firstReadyCategory
    ? "Practicar preguntas clave"
    : "Ver categorias";

const learnStats = [
  {
    label: "Preguntas clave",
    value: totalQuestions,
    help: "Banco activo",
    icon: BookOpen,
    tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200"
  },
  {
    label: "Categorias",
    value: categories.length,
    help: `${readyCategories.length} listas para practicar`,
    icon: CircleCheck,
    tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
  },
  {
    label: "Por practica",
    value: settings.questionsPerGame,
    help: "Preguntas al azar",
    icon: ListChecks,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200"
  },
  {
    label: "Tiempo medio",
    value: averageMinutes,
    help: "Intentos completados",
    icon: Clock3,
    tone: "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
  }
];

const learningSteps = [
  {
    title: "Lee con intencion",
    description: "Identifica que tema evalua cada pregunta antes de elegir una respuesta.",
    icon: BookOpen
  },
  {
    title: "Responde una ronda",
    description: `Completa ${settings.questionsPerGame} preguntas para obtener una senal clara sin saturarte.`,
    icon: Play
  },
  {
    title: "Revisa el detalle",
    description: "Separa aciertos de errores y convierte cada fallo en una pista de estudio.",
    icon: BookCheck
  },
  {
    title: "Vuelve al punto clave",
    description: "Repite la categoria hasta que el resultado deje de depender del azar.",
    icon: RotateCcw
  }
];

const focusCards = [
  {
    title: "Conceptos base",
    description: "Empieza por categorias listas para construir seguridad antes de subir el ritmo.",
    icon: BookOpen,
    tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200",
    href: "/conceptos-base"
  },
  {
    title: "Preguntas al azar",
    description: "Cada intento mezcla el banco disponible para evitar memorizar solo el orden.",
    icon: ListChecks,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200",
    href: "/preguntas-al-azar"
  },
  {
    title: "Repaso dirigido",
    description: "Los resultados te muestran donde volver para reforzar con mas precision.",
    icon: Target,
    tone: "bg-rose-50 text-rose-700 dark:bg-rose-500/15 dark:text-rose-200",
    href: "/repaso-dirigido"
  }
];
---

<BaseLayout
  title="Aprende | Eus3 Simulador"
  description="Refuerza tus conocimientos en EUS3 con preguntas clave, practica por categorias y revision de resultados."
  canonical="/aprende"
>
  <main id="contenido" class="min-h-screen px-3 pb-[calc(6rem+env(safe-area-inset-bottom))] pt-3 sm:px-5 sm:pt-5 lg:p-6">
    <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
      <PublicSidebar active="home" />

      <section class="min-w-0 rounded-lg border border-slate-200/80 bg-white/86 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/84">
        <header class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-3 dark:border-white/10 sm:px-5">
          <a href="/" class="flex min-w-0 items-center gap-3 lg:hidden">
            <img src="/img/eus-logo.png" alt="Eus3" class="h-10 w-10 rounded-md object-contain" />
            <div class="min-w-0">
              <p class="text-[10px] font-bold uppercase text-orange-600 dark:text-orange-300">Simulador</p>
              <p class="truncate text-sm font-bold text-slate-950 dark:text-white">Semilla Digital</p>
            </div>
          </a>

          <div class="hidden lg:block">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">Aprendizaje</p>
            <p class="text-sm font-bold text-slate-950 dark:text-white">Aprende</p>
          </div>

          <button
            type="button"
            class="focus-ring ml-auto grid h-10 w-10 place-items-center rounded-md border border-slate-200 bg-white text-slate-700 shadow-sm hover:border-orange-200 hover:text-orange-700 dark:border-white/10 dark:bg-slate-900 dark:text-slate-200 dark:hover:text-orange-200"
            aria-label="Cambiar tema"
            data-theme-toggle
          >
            <Sun size={18} class="dark:hidden" aria-hidden="true" />
            <Moon size={18} class="hidden dark:block" aria-hidden="true" />
          </button>
        </header>

        <div class="p-4 sm:p-6 lg:p-8">
          <section class="grid items-start gap-4 xl:grid-cols-[minmax(0,1.25fr)_340px]">
            <article class="overflow-hidden rounded-lg border border-amber-200 bg-slate-950 text-white shadow-lg shadow-amber-950/10 dark:border-white/10">
              <div class="relative min-h-[23rem] bg-[linear-gradient(105deg,rgba(15,23,42,0.96),rgba(217,119,6,0.78)_50%,rgba(22,101,52,0.68)),url('/img/fondoAzul-marino.jpg')] bg-cover bg-center p-5 sm:min-h-80 sm:p-7">
                <div class="absolute right-7 top-7 hidden h-28 w-28 rounded-md border border-white/20 sm:block" aria-hidden="true"></div>
                <div class="absolute bottom-9 right-16 hidden h-20 w-20 rounded-full border border-white/25 sm:block" aria-hidden="true"></div>
                <div class="relative z-10 flex min-h-[20rem] flex-col justify-between sm:min-h-[16.5rem]">
                  <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-2 rounded-md bg-white/15 px-3 py-1.5 text-xs font-bold uppercase text-amber-50 backdrop-blur">
                      <BookOpen size={15} aria-hidden="true" />
                      Aprende
                    </span>
                    <h1 class="mt-5 max-w-2xl text-3xl font-black leading-tight sm:text-4xl">
                      Refuerza tus conocimientos con preguntas clave.
                    </h1>
                    <p class="mt-4 max-w-xl text-sm leading-6 text-amber-50 sm:text-base">
                      Usa el banco de preguntas para entender patrones, practicar por categoria y convertir cada intento en aprendizaje medible.
                    </p>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                    <a href={primaryHref} class="focus-ring inline-flex w-fit items-center justify-center gap-2 rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm hover:bg-amber-50">
                      {primaryLabel}
                      <Play size={16} fill="currentColor" aria-hidden="true" />
                    </a>
                    <a href="#preguntas-clave" class="focus-ring inline-flex w-fit items-center justify-center gap-2 rounded-md border border-white/25 bg-white/10 px-4 py-3 text-sm font-bold text-white backdrop-blur hover:bg-white/15">
                      Ver banco
                      <ChevronRight size={16} aria-hidden="true" />
                    </a>
                  </div>
                </div>
              </div>
            </article>

            <aside class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-base font-bold text-slate-950 dark:text-white">Metodo de aprendizaje</h2>
                  <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Una forma simple de estudiar con preguntas.</p>
                </div>
                <Trophy size={22} class="text-amber-600 dark:text-amber-300" aria-hidden="true" />
              </div>

              <div class="mt-5 space-y-4">
                {learningSteps.map((step, index) => {
                  const Icon = step.icon;
                  return (
                    <div class="grid grid-cols-[44px_1fr] gap-3">
                      <span class="grid h-11 w-11 place-items-center rounded-md bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200">
                        <Icon size={20} aria-hidden="true" />
                      </span>
                      <div>
                        <p class="text-sm font-bold text-slate-950 dark:text-white">{index + 1}. {step.title}</p>
                        <p class="mt-1 text-xs leading-5 text-slate-600 dark:text-slate-400">{step.description}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            </aside>
          </section>

          <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {learnStats.map((card) => {
              const Icon = card.icon;
              return (
                <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{card.label}</p>
                      <p class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{card.value}</p>
                    </div>
                    <span class:list={["grid h-10 w-10 place-items-center rounded-md", card.tone]}>
                      <Icon size={20} aria-hidden="true" />
                    </span>
                  </div>
                  <p class="mt-3 text-xs text-slate-600 dark:text-slate-400">{card.help}</p>
                </article>
              );
            })}
          </section>

          <section class="mt-6 grid gap-3 md:grid-cols-3">
            {focusCards.map((card) => {
              const Icon = card.icon;
              return (
                <a href={card.href} class="focus-ring group rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-orange-200 hover:shadow-md dark:border-white/10 dark:bg-slate-900 dark:hover:border-orange-400/40">
                  <div class:list={["grid h-11 w-11 place-items-center rounded-md", card.tone]}>
                    <Icon size={21} aria-hidden="true" />
                  </div>
                  <h2 class="mt-4 text-base font-bold text-slate-950 dark:text-white">{card.title}</h2>
                  <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">{card.description}</p>
                  <span class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-orange-700 group-hover:text-orange-800 dark:text-orange-300 dark:group-hover:text-orange-200">
                    Abrir
                    <ChevronRight size={16} aria-hidden="true" />
                  </span>
                </a>
              );
            })}
          </section>

          <section id="preguntas-clave" class="mt-6">
            <div class="mb-4 flex flex-col justify-between gap-2 sm:flex-row sm:items-end">
              <div>
                <h2 class="text-xl font-bold text-slate-950 dark:text-white">Banco de preguntas clave</h2>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                  Revisa el volumen de preguntas por categoria y empieza por las que ya estan listas.
                </p>
              </div>
              <span class="w-fit rounded-md bg-amber-50 px-3 py-1 text-xs font-bold text-amber-700 dark:bg-amber-500/15 dark:text-amber-200">
                {bankCoverage}% cobertura
              </span>
            </div>

            {categories.length === 0 ? (
              <div class="rounded-lg border border-dashed border-slate-300 bg-white/85 p-8 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h3 class="text-lg font-bold text-slate-950 dark:text-white">Todavia no hay preguntas</h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Cuando existan categorias con preguntas, este banco mostrara por donde empezar.</p>
              </div>
            ) : (
              <div class="grid gap-3">
                {categories.map((category, index) => {
                  const ready = category.questionCount >= settings.questionsPerGame;
                  const percent = Math.min(100, Math.round((category.questionCount * 100) / Math.max(settings.questionsPerGame, 1)));
                  const attempt = attemptByCategory.get(category.id);
                  const focusLabel = !attempt
                    ? "Primer intento"
                    : attempt.averageScore < 70
                      ? "Reforzar base"
                      : "Consolidar";

                  return (
                    <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-amber-200 hover:shadow-md dark:border-white/10 dark:bg-slate-900 dark:hover:border-amber-400/40 sm:p-5">
                      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_150px_190px_150px] lg:items-center">
                        <div class="flex min-w-0 gap-3">
                          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-md bg-amber-50 text-sm font-black text-amber-700 dark:bg-amber-500/15 dark:text-amber-200">
                            {String(index + 1).padStart(2, "0")}
                          </span>
                          <div class="min-w-0">
                            <h3 class="text-base font-bold text-slate-950 dark:text-white">{category.name}</h3>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                              {category.questionCount} preguntas disponibles
                            </p>
                          </div>
                        </div>

                        <div>
                          <p class="text-xs font-bold text-slate-500 dark:text-slate-400">Foco sugerido</p>
                          <p class="mt-1 text-sm font-black text-slate-950 dark:text-white">{focusLabel}</p>
                        </div>

                        <div>
                          <div class="mb-1 flex justify-between text-xs font-bold text-slate-500 dark:text-slate-400">
                            <span>{percent}% banco minimo</span>
                            <span>{settings.questionsPerGame}</span>
                          </div>
                          <div class="h-2 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800">
                            <div class:list={["h-full rounded-md", ready ? "bg-amber-500" : "bg-orange-500"]} style={`width: ${percent}%`}></div>
                          </div>
                        </div>

                        <div class="flex items-center justify-between gap-3 lg:justify-end">
                          <span class:list={[
                            "shrink-0 rounded-md px-2.5 py-1 text-xs font-bold",
                            ready
                              ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                              : "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
                          ]}>
                            {ready ? "Lista" : "Incompleta"}
                          </span>

                          {ready ? (
                            <a href={`/jugar/${category.id}`} class="focus-ring inline-flex items-center gap-2 rounded-md bg-amber-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-amber-700">
                              <Play size={16} fill="currentColor" aria-hidden="true" />
                              Practicar
                            </a>
                          ) : (
                            <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">
                              Faltan {Math.max(settings.questionsPerGame - category.questionCount, 0)}
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            )}
          </section>

          <section class="mt-6 rounded-lg border border-emerald-200 bg-emerald-50/70 p-5 dark:border-emerald-400/20 dark:bg-emerald-500/10">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-base font-bold text-emerald-950 dark:text-emerald-100">Siguiente paso</h2>
                <p class="mt-2 max-w-2xl text-sm leading-6 text-emerald-900 dark:text-emerald-100/80">
                  Elige una categoria lista, completa una ronda y usa el detalle final para decidir que pregunta o tema reforzar despues.
                </p>
              </div>
              <Target size={34} class="text-emerald-700 dark:text-emerald-200" aria-hidden="true" />
            </div>
          </section>
        </div>
      </section>
    </div>
    <PublicMobileNav active="home" />
  </main>
</BaseLayout>
