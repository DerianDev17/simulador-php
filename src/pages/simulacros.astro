---
import PublicSidebar from "@/components/PublicSidebar.astro";
import PublicMobileNav from "@/components/PublicMobileNav.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BenefitCard from "@/components/BenefitCard.astro";
import { gameSessionCookie, getGameResult } from "@/lib/game";
import { ensureLearnerId } from "@/lib/learner";
import { ensureDefaultSettings, getCategory, getQuizReportSummary, listCategorySummaries } from "@/lib/store";
import ChartColumn from "@lucide/astro/icons/chart-column";
import ChevronRight from "@lucide/astro/icons/chevron-right";
import CircleAlert from "@lucide/astro/icons/circle-alert";
import CircleCheck from "@lucide/astro/icons/circle-check";
import Clock3 from "@lucide/astro/icons/clock-3";
import ListChecks from "@lucide/astro/icons/list-checks";
import Moon from "@lucide/astro/icons/moon";
import Play from "@lucide/astro/icons/play";
import Rocket from "@lucide/astro/icons/rocket";
import Sun from "@lucide/astro/icons/sun";
import Target from "@lucide/astro/icons/target";
import Timer from "@lucide/astro/icons/timer";
import Trophy from "@lucide/astro/icons/trophy";

const settings = ensureDefaultSettings();
const learnerId = ensureLearnerId(Astro.cookies, Astro.request);
const report = getQuizReportSummary(learnerId);
const categories = listCategorySummaries();
const readyCategories = categories.filter((category) => category.questionCount >= settings.questionsPerGame);
const pendingCategories = categories.filter((category) => category.questionCount < settings.questionsPerGame);
const totalQuestions = categories.reduce((total, category) => total + category.questionCount, 0);
const firstReadyCategory = readyCategories[0];
const heroHref = firstReadyCategory ? `/jugar/${firstReadyCategory.id}` : "#disponibles";
const heroLabel = firstReadyCategory ? "Iniciar simulacro" : "Ver disponibles";
const estimatedMinutes = Math.max(settings.questionsPerGame * 2, 1);
const progressPercent = report.totalAttempts > 0 ? report.averageScore : 0;
const progressDegrees = Math.round((progressPercent / 100) * 360);

const currentGame = getGameResult(Astro.cookies.get(gameSessionCookie)?.value, learnerId);
const activeCategory = currentGame.status === "incomplete" ? getCategory(currentGame.categoryId) : undefined;

const summaryCards = [
  {
    label: "Listos",
    value: readyCategories.length,
    help: "Simulacros disponibles",
    icon: CircleCheck,
    tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
  },
  {
    label: "Pendientes",
    value: pendingCategories.length,
    help: "Necesitan mas preguntas",
    icon: CircleAlert,
    tone: "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
  },
  {
    label: "Duracion",
    value: `${estimatedMinutes} min`,
    help: `${settings.questionsPerGame} preguntas por intento`,
    icon: Timer,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200"
  },
  {
    label: "Banco",
    value: totalQuestions,
    help: "Preguntas activas",
    icon: ListChecks,
    tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200"
  }
];

const supportCards = [
  {
    title: "Practica enfocada",
    description: "Cada intento toma preguntas al azar de una categoria lista.",
    icon: Target,
    tone: "bg-rose-50 text-rose-700 dark:bg-rose-500/15 dark:text-rose-200",
    href: "/practica-enfocada"
  },
  {
    title: "Ritmo constante",
    description: "Mantiene sesiones cortas para repasar sin perder foco.",
    icon: Clock3,
    tone: "bg-slate-100 text-slate-700 dark:bg-white/10 dark:text-slate-200",
    href: "/ritmo-constante"
  },
  {
    title: "Mejora continua",
    description: "El resultado final actualiza tus estadisticas generales.",
    icon: Rocket,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200"
  }
];
---

<BaseLayout
  title="Simulacros | Eus3 Simulador"
  description="Inicia simulacros por categoria en EUS3, mide tu precision y revisa tus intentos completados."
  canonical="/simulacros"
>
  <main id="contenido" class="min-h-screen px-3 pb-[calc(6rem+env(safe-area-inset-bottom))] pt-3 sm:px-5 sm:pt-5 lg:p-6">
    <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
      <PublicSidebar active="simulations" />

      <section class="min-w-0 rounded-lg border border-slate-200/80 bg-white/86 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/84">
        <header class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-3 dark:border-white/10 sm:px-5">
          <a href="/" class="flex min-w-0 items-center gap-3 lg:hidden">
            <img src="/img/eus-logo.png" alt="Eus3" class="h-10 w-10 rounded-md object-contain" />
            <div class="min-w-0">
              <p class="text-[10px] font-bold uppercase text-orange-600 dark:text-orange-300">Simulador</p>
              <p class="truncate text-sm font-bold text-slate-950 dark:text-white">EUS3 Preuniversitario</p>
            </div>
          </a>

          <div class="hidden lg:block">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">Practica</p>
            <p class="text-sm font-bold text-slate-950 dark:text-white">Simulacros</p>
          </div>

          <div class="ml-auto flex items-center gap-2">
            <button
              type="button"
              class="focus-ring grid h-10 w-10 place-items-center rounded-md border border-slate-200 bg-white text-slate-700 shadow-sm hover:border-orange-200 hover:text-orange-700 dark:border-white/10 dark:bg-slate-900 dark:text-slate-200 dark:hover:text-orange-200"
              aria-label="Cambiar tema"
              data-theme-toggle
            >
              <Sun size={18} class="dark:hidden" aria-hidden="true" />
              <Moon size={18} class="hidden dark:block" aria-hidden="true" />
            </button>

          </div>
        </header>

        <div class="p-4 sm:p-6 lg:p-8">
          <div class="mb-6 flex flex-col justify-between gap-3 xl:flex-row xl:items-end">
            <div>
              <h1 class="text-2xl font-bold leading-tight text-slate-950 dark:text-white sm:text-3xl">Simulacros</h1>
              <p class="mt-1 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
                Elige una categoria lista y completa un intento de {settings.questionsPerGame} preguntas.
              </p>
            </div>

            {activeCategory && (
              <a href={`/jugar/${activeCategory.id}`} class="focus-ring inline-flex w-fit items-center gap-2 rounded-md border border-orange-200 bg-orange-50 px-4 py-3 text-sm font-bold text-orange-700 hover:bg-orange-100 dark:border-orange-400/30 dark:bg-orange-500/15 dark:text-orange-200 dark:hover:bg-orange-500/25">
                Continuar {activeCategory.name}
                <ChevronRight size={16} aria-hidden="true" />
              </a>
            )}
          </div>

          <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {summaryCards.map((card) => {
              const Icon = card.icon;
              return (
                <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{card.label}</p>
                      <p class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{card.value}</p>
                    </div>
                    <span class:list={["grid h-10 w-10 place-items-center rounded-md", card.tone]}>
                      <Icon size={20} aria-hidden="true" />
                    </span>
                  </div>
                  <p class="mt-3 text-xs text-slate-600 dark:text-slate-400">{card.help}</p>
                </article>
              );
            })}
          </section>

          <section class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,1.3fr)_330px]">
            <article class="overflow-hidden rounded-lg border border-orange-500/20 bg-orange-600 text-white shadow-lg shadow-orange-900/10">
              <div class="relative min-h-64 bg-[linear-gradient(90deg,rgba(234,88,12,0.98),rgba(249,115,22,0.82)),url('/img/fondoNaranja.jpg')] bg-cover bg-center p-5 sm:p-7">
                <div class="relative z-10 max-w-xl">
                  <p class="text-xs font-bold uppercase text-orange-100">Simulacro por categoria</p>
                  <h2 class="mt-4 text-3xl font-black leading-tight sm:text-4xl">Pon a prueba tu ritmo de examen</h2>
                  <p class="mt-4 max-w-md text-sm leading-6 text-orange-50">
                    Inicia un intento con preguntas aleatorias y revisa el resultado al terminar.
                  </p>
                  <a href={heroHref} class="focus-ring mt-6 inline-flex items-center gap-2 rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm hover:bg-orange-50">
                    {heroLabel}
                    <Play size={16} fill="currentColor" aria-hidden="true" />
                  </a>
                </div>
                <Trophy size={132} class="absolute bottom-5 right-5 text-orange-200/70" aria-hidden="true" />
              </div>
            </article>

            <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-base font-bold text-slate-950 dark:text-white">Progreso de simulacros</h2>
                  <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Basado en intentos completados.</p>
                </div>
                <ChartColumn size={22} class="text-orange-600 dark:text-orange-300" aria-hidden="true" />
              </div>

              <div class="mt-5 grid grid-cols-[108px_1fr] items-center gap-5">
                <div
                  class="grid h-28 w-28 place-items-center rounded-full"
                  style={`background: conic-gradient(#f97316 ${progressDegrees}deg, #e2e8f0 0deg);`}
                >
                  <div class="grid h-20 w-20 place-items-center rounded-full bg-white text-center shadow-inner dark:bg-slate-900">
                    <div>
                      <p class="text-2xl font-black text-slate-950 dark:text-white">{progressPercent}%</p>
                      <p class="text-[11px] font-semibold text-slate-500 dark:text-slate-400">Precision</p>
                    </div>
                  </div>
                </div>

                <div class="space-y-3">
                  <div>
                    <p class="text-lg font-black text-slate-950 dark:text-white">{report.totalAttempts}</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Terminados</p>
                  </div>
                  <div>
                    <p class="text-lg font-black text-slate-950 dark:text-white">{report.totalAnswered}</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Preguntas respondidas</p>
                  </div>
                </div>
              </div>
            </article>
          </section>

          <section id="disponibles" class="mt-6">
            <div class="mb-4 flex flex-col justify-between gap-2 sm:flex-row sm:items-end">
              <div>
                <h2 class="text-xl font-bold text-slate-950 dark:text-white">Simulacros disponibles</h2>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Cada categoria lista abre una partida nueva.</p>
              </div>
              <span class="w-fit rounded-md bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200">
                {readyCategories.length} listos
              </span>
            </div>

            {categories.length === 0 ? (
              <div class="rounded-lg border border-dashed border-slate-300 bg-white/85 p-8 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h3 class="text-lg font-bold text-slate-950 dark:text-white">Todavia no hay categorias</h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Los simulacros apareceran cuando exista una categoria disponible.</p>
              </div>
            ) : (
              <div class="grid gap-3">
                {categories.map((category, index) => {
                  const ready = category.questionCount >= settings.questionsPerGame;
                  const percent = Math.min(100, Math.round((category.questionCount * 100) / Math.max(settings.questionsPerGame, 1)));
                  return (
                    <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-orange-200 hover:shadow-md dark:border-white/10 dark:bg-slate-900 dark:hover:border-orange-400/40 sm:p-5">
                      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_180px_150px] lg:items-center">
                        <div class="flex min-w-0 gap-3">
                          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-md bg-orange-50 text-sm font-black text-orange-700 dark:bg-orange-500/15 dark:text-orange-200">
                            {String(index + 1).padStart(2, "0")}
                          </span>
                          <div class="min-w-0">
                            <h3 class="text-base font-bold text-slate-950 dark:text-white">{category.name}</h3>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                              {category.questionCount} preguntas disponibles
                            </p>
                          </div>
                        </div>

                        <div>
                          <div class="mb-1 flex justify-between text-xs font-bold text-slate-500 dark:text-slate-400">
                            <span>{percent}% banco minimo</span>
                            <span>{settings.questionsPerGame}</span>
                          </div>
                          <div class="h-2 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800">
                            <div class:list={["h-full rounded-md", ready ? "bg-emerald-500" : "bg-orange-500"]} style={`width: ${percent}%`}></div>
                          </div>
                        </div>

                        <div class="flex items-center justify-between gap-3 lg:justify-end">
                          <span class:list={[
                            "shrink-0 rounded-md px-2.5 py-1 text-xs font-bold",
                            ready
                              ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                              : "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
                          ]}>
                            {ready ? "Lista" : "Incompleta"}
                          </span>

                          {ready ? (
                            <a href={`/jugar/${category.id}`} class="focus-ring inline-flex items-center gap-2 rounded-md bg-orange-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-orange-700">
                              <Play size={16} fill="currentColor" aria-hidden="true" />
                              Iniciar
                            </a>
                          ) : (
                            <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">
                              Faltan {Math.max(settings.questionsPerGame - category.questionCount, 0)}
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            )}
          </section>

          <section class="mt-6 grid gap-3 md:grid-cols-3">
            {supportCards.map((card) => {
              return (
                <BenefitCard title={card.title} description={card.description} icon={card.icon} tone={card.tone} href={card.href} />
              );
            })}
          </section>
        </div>
      </section>
    </div>
    <PublicMobileNav active="simulations" />
  </main>
</BaseLayout>
