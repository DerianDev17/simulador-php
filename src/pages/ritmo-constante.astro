---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicMobileNav from "@/components/PublicMobileNav.astro";
import PublicSidebar from "@/components/PublicSidebar.astro";
import { gameSessionCookie, getGameResult } from "@/lib/game";
import { ensureLearnerId } from "@/lib/learner";
import { ensureDefaultSettings, getCategory, getQuizReportSummary, listCategorySummaries } from "@/lib/store";
import BookOpen from "@lucide/astro/icons/book-open";
import ChevronRight from "@lucide/astro/icons/chevron-right";
import CircleCheck from "@lucide/astro/icons/circle-check";
import Clock3 from "@lucide/astro/icons/clock-3";
import ListChecks from "@lucide/astro/icons/list-checks";
import Moon from "@lucide/astro/icons/moon";
import Play from "@lucide/astro/icons/play";
import RotateCcw from "@lucide/astro/icons/rotate-ccw";
import Sun from "@lucide/astro/icons/sun";
import Target from "@lucide/astro/icons/target";
import Timer from "@lucide/astro/icons/timer";
import Trophy from "@lucide/astro/icons/trophy";

const settings = ensureDefaultSettings();
const learnerId = ensureLearnerId(Astro.cookies, Astro.request);
const report = getQuizReportSummary(learnerId);
const categories = listCategorySummaries();
const readyCategories = categories.filter((category) => category.questionCount >= settings.questionsPerGame);
const firstReadyCategory = readyCategories[0];
const currentGame = getGameResult(Astro.cookies.get(gameSessionCookie)?.value, learnerId);
const activeCategory = currentGame.status === "incomplete" ? getCategory(currentGame.categoryId) : undefined;
const suggestedMinutes = Math.max(settings.questionsPerGame * 2, 1);
const averageMinutes = report.averageDurationSeconds > 0 ? `${Math.max(1, Math.round(report.averageDurationSeconds / 60))} min` : "Sin datos";

const primaryHref = activeCategory
  ? `/jugar/${activeCategory.id}`
  : firstReadyCategory
    ? `/jugar/${firstReadyCategory.id}`
    : "/simulacros";

const primaryLabel = activeCategory
  ? `Continuar ${activeCategory.name}`
  : firstReadyCategory
    ? "Iniciar ronda corta"
    : "Ver simulacros";

const rhythmStats = [
  {
    label: "Duracion sugerida",
    value: `${suggestedMinutes} min`,
    help: "Ronda breve de estudio",
    icon: Timer,
    tone: "bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200"
  },
  {
    label: "Preguntas",
    value: settings.questionsPerGame,
    help: "Por intento",
    icon: ListChecks,
    tone: "bg-orange-50 text-orange-700 dark:bg-orange-500/15 dark:text-orange-200"
  },
  {
    label: "Terminados",
    value: report.totalAttempts,
    help: "Intentos registrados",
    icon: CircleCheck,
    tone: "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
  },
  {
    label: "Tiempo medio",
    value: averageMinutes,
    help: "Tus partidas completas",
    icon: Clock3,
    tone: "bg-slate-100 text-slate-700 dark:bg-white/10 dark:text-slate-200"
  }
];

const rhythmSteps = [
  {
    title: "Prepara el foco",
    description: "Elige una categoria y evita cambiar de tema hasta terminar la ronda.",
    icon: Target,
    minutes: "1 min"
  },
  {
    title: "Responde sin pausas largas",
    description: `Completa ${settings.questionsPerGame} preguntas con un ritmo sostenido.`,
    icon: Play,
    minutes: `${suggestedMinutes} min`
  },
  {
    title: "Revisa lo importante",
    description: "Mira el detalle final y detecta solo el error que debes corregir primero.",
    icon: BookOpen,
    minutes: "3 min"
  },
  {
    title: "Repite si hace falta",
    description: "Haz otra ronda corta cuando la categoria siga quedando por debajo de tu objetivo.",
    icon: RotateCcw,
    minutes: "1 ronda"
  }
];
---

<BaseLayout
  title="Ritmo constante | Eus3 Simulador"
  description="Practica en sesiones cortas con el simulador EUS3 para mantener un ritmo constante de preparacion."
  canonical="/ritmo-constante"
>
  <main id="contenido" class="min-h-screen px-3 pb-[calc(6rem+env(safe-area-inset-bottom))] pt-3 sm:px-5 sm:pt-5 lg:p-6">
    <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[240px_minmax(0,1fr)]">
      <PublicSidebar active="simulations" />

      <section class="min-w-0 rounded-lg border border-slate-200/80 bg-white/86 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/84">
        <header class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-3 dark:border-white/10 sm:px-5">
          <a href="/" class="flex min-w-0 items-center gap-3 lg:hidden">
            <img src="/img/eus-logo.png" alt="Eus3" class="h-10 w-10 rounded-md object-contain" />
            <div class="min-w-0">
              <p class="text-[10px] font-bold uppercase text-orange-600 dark:text-orange-300">Simulador</p>
              <p class="truncate text-sm font-bold text-slate-950 dark:text-white">EUS3 Preuniversitario</p>
            </div>
          </a>

          <div class="hidden lg:block">
            <p class="text-xs font-semibold text-slate-500 dark:text-slate-400">Practica</p>
            <p class="text-sm font-bold text-slate-950 dark:text-white">Ritmo constante</p>
          </div>

          <button
            type="button"
            class="focus-ring ml-auto grid h-10 w-10 place-items-center rounded-md border border-slate-200 bg-white text-slate-700 shadow-sm hover:border-orange-200 hover:text-orange-700 dark:border-white/10 dark:bg-slate-900 dark:text-slate-200 dark:hover:text-orange-200"
            aria-label="Cambiar tema"
            data-theme-toggle
          >
            <Sun size={18} class="dark:hidden" aria-hidden="true" />
            <Moon size={18} class="hidden dark:block" aria-hidden="true" />
          </button>
        </header>

        <div class="p-4 sm:p-6 lg:p-8">
          <section class="grid items-start gap-4 xl:grid-cols-[minmax(0,1.25fr)_340px]">
            <article class="overflow-hidden rounded-lg border border-sky-200 bg-slate-950 text-white shadow-lg shadow-sky-950/10 dark:border-white/10">
              <div class="relative min-h-[23rem] bg-[linear-gradient(105deg,rgba(7,89,133,0.96),rgba(14,165,233,0.76)_54%,rgba(15,23,42,0.76)),url('/img/fondoazulM.jpg')] bg-cover bg-center p-5 sm:min-h-80 sm:p-7">
                <div class="absolute right-7 top-7 hidden h-28 w-28 rounded-full border border-white/20 sm:block" aria-hidden="true"></div>
                <div class="absolute bottom-8 right-14 hidden h-16 w-16 rounded-md border border-white/25 sm:block" aria-hidden="true"></div>
                <div class="relative z-10 flex min-h-[20rem] flex-col justify-between sm:min-h-[16.5rem]">
                  <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-2 rounded-md bg-white/15 px-3 py-1.5 text-xs font-bold uppercase text-sky-50 backdrop-blur">
                      <Clock3 size={15} aria-hidden="true" />
                      Ritmo constante
                    </span>
                    <h1 class="mt-5 max-w-2xl text-3xl font-black leading-tight sm:text-4xl">
                      Mantén sesiones cortas para repasar sin perder foco.
                    </h1>
                    <p class="mt-4 max-w-xl text-sm leading-6 text-sky-50 sm:text-base">
                      Trabaja por bloques breves, revisa al terminar y vuelve a intentarlo con una meta concreta.
                    </p>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                    <a href={primaryHref} class="focus-ring inline-flex w-fit items-center justify-center gap-2 rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm hover:bg-sky-50">
                      {primaryLabel}
                      <Play size={16} fill="currentColor" aria-hidden="true" />
                    </a>
                    <a href="#rondas-cortas" class="focus-ring inline-flex w-fit items-center justify-center gap-2 rounded-md border border-white/25 bg-white/10 px-4 py-3 text-sm font-bold text-white backdrop-blur hover:bg-white/15">
                      Ver rondas
                      <ChevronRight size={16} aria-hidden="true" />
                    </a>
                  </div>
                </div>
              </div>
            </article>

            <aside class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-base font-bold text-slate-950 dark:text-white">Bloque recomendado</h2>
                  <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Un ciclo corto y repetible.</p>
                </div>
                <Timer size={22} class="text-sky-600 dark:text-sky-300" aria-hidden="true" />
              </div>

              <div class="mt-5 space-y-3">
                {rhythmSteps.map((step, index) => {
                  const Icon = step.icon;
                  return (
                    <div class="grid grid-cols-[44px_1fr_auto] items-start gap-3 rounded-md border border-slate-100 p-3 dark:border-white/10">
                      <span class="grid h-11 w-11 place-items-center rounded-md bg-sky-50 text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">
                        <Icon size={20} aria-hidden="true" />
                      </span>
                      <div>
                        <p class="text-sm font-bold text-slate-950 dark:text-white">{index + 1}. {step.title}</p>
                        <p class="mt-1 text-xs leading-5 text-slate-600 dark:text-slate-400">{step.description}</p>
                      </div>
                      <span class="rounded-md bg-slate-100 px-2 py-1 text-[11px] font-bold text-slate-600 dark:bg-white/10 dark:text-slate-300">
                        {step.minutes}
                      </span>
                    </div>
                  );
                })}
              </div>
            </aside>
          </section>

          <section class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {rhythmStats.map((card) => {
              const Icon = card.icon;
              return (
                <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-white/10 dark:bg-slate-900">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{card.label}</p>
                      <p class="mt-2 text-2xl font-black text-slate-950 dark:text-white">{card.value}</p>
                    </div>
                    <span class:list={["grid h-10 w-10 place-items-center rounded-md", card.tone]}>
                      <Icon size={20} aria-hidden="true" />
                    </span>
                  </div>
                  <p class="mt-3 text-xs text-slate-600 dark:text-slate-400">{card.help}</p>
                </article>
              );
            })}
          </section>

          <section id="rondas-cortas" class="mt-6">
            <div class="mb-4 flex flex-col justify-between gap-2 sm:flex-row sm:items-end">
              <div>
                <h2 class="text-xl font-bold text-slate-950 dark:text-white">Rondas cortas disponibles</h2>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                  Elige una categoria lista y completa una sesion breve.
                </p>
              </div>
              <span class="w-fit rounded-md bg-sky-50 px-3 py-1 text-xs font-bold text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">
                {readyCategories.length} listas
              </span>
            </div>

            {categories.length === 0 ? (
              <div class="rounded-lg border border-dashed border-slate-300 bg-white/85 p-8 text-center shadow-sm dark:border-white/10 dark:bg-slate-900">
                <h3 class="text-lg font-bold text-slate-950 dark:text-white">Todavia no hay categorias</h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Cuando exista una categoria con preguntas suficientes, podras iniciar una ronda corta.</p>
              </div>
            ) : (
              <div class="grid gap-3">
                {categories.map((category, index) => {
                  const ready = category.questionCount >= settings.questionsPerGame;
                  const percent = Math.min(100, Math.round((category.questionCount * 100) / Math.max(settings.questionsPerGame, 1)));
                  return (
                    <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-sky-200 hover:shadow-md dark:border-white/10 dark:bg-slate-900 dark:hover:border-sky-400/40 sm:p-5">
                      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_170px_190px_150px] lg:items-center">
                        <div class="flex min-w-0 gap-3">
                          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-md bg-sky-50 text-sm font-black text-sky-700 dark:bg-sky-500/15 dark:text-sky-200">
                            {String(index + 1).padStart(2, "0")}
                          </span>
                          <div class="min-w-0">
                            <h3 class="text-base font-bold text-slate-950 dark:text-white">{category.name}</h3>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                              {category.questionCount} preguntas disponibles
                            </p>
                          </div>
                        </div>

                        <div>
                          <p class="text-xs font-bold text-slate-500 dark:text-slate-400">Tiempo sugerido</p>
                          <p class="mt-1 text-sm font-black text-slate-950 dark:text-white">{suggestedMinutes} minutos</p>
                        </div>

                        <div>
                          <div class="mb-1 flex justify-between text-xs font-bold text-slate-500 dark:text-slate-400">
                            <span>{percent}% banco minimo</span>
                            <span>{settings.questionsPerGame}</span>
                          </div>
                          <div class="h-2 overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800">
                            <div class:list={["h-full rounded-md", ready ? "bg-sky-500" : "bg-orange-500"]} style={`width: ${percent}%`}></div>
                          </div>
                        </div>

                        <div class="flex items-center justify-between gap-3 lg:justify-end">
                          <span class:list={[
                            "shrink-0 rounded-md px-2.5 py-1 text-xs font-bold",
                            ready
                              ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-200"
                              : "bg-amber-50 text-amber-700 dark:bg-amber-500/15 dark:text-amber-200"
                          ]}>
                            {ready ? "Lista" : "Incompleta"}
                          </span>

                          {ready ? (
                            <a href={`/jugar/${category.id}`} class="focus-ring inline-flex items-center gap-2 rounded-md bg-sky-600 px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-sky-700">
                              <Play size={16} fill="currentColor" aria-hidden="true" />
                              Iniciar
                            </a>
                          ) : (
                            <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">
                              Faltan {Math.max(settings.questionsPerGame - category.questionCount, 0)}
                            </span>
                          )}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            )}
          </section>

          <section class="mt-6 rounded-lg border border-sky-200 bg-sky-50/70 p-5 dark:border-sky-400/20 dark:bg-sky-500/10">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-base font-bold text-sky-950 dark:text-sky-100">Meta de ritmo</h2>
                <p class="mt-2 max-w-2xl text-sm leading-6 text-sky-900 dark:text-sky-100/80">
                  Completa una ronda, revisa solo lo necesario y vuelve despues. La constancia depende de sesiones que puedas repetir.
                </p>
              </div>
              <Trophy size={34} class="text-sky-700 dark:text-sky-200" aria-hidden="true" />
            </div>
          </section>
        </div>
      </section>
    </div>
    <PublicMobileNav active="simulations" />
  </main>
</BaseLayout>
