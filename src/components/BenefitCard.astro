---
const { title, description, icon: Icon, tone, href } = Astro.props;

const baseClasses =
  "alive-card flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 shadow-sm shadow-slate-900/5 dark:border-white/10 dark:bg-slate-900 sm:p-6";
const linkClasses =
  "alive-card group flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 shadow-sm shadow-slate-900/5 transition hover:border-orange-200 dark:border-white/10 dark:bg-slate-900 dark:hover:border-orange-400/40 sm:p-6";
---

{href ? (
  <a href={href} class:list={["focus-ring block", linkClasses]}>
    <div class:list={["grid h-12 w-12 place-items-center rounded-md transition group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100", tone]}>
      <Icon size={25} aria-hidden="true" />
    </div>
    <h3 class="mt-5 text-lg font-bold leading-tight text-slate-950 dark:text-white">{title}</h3>
    <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{description}</p>
  </a>
) : (
  <article class={baseClasses}>
    <div class:list={["grid h-12 w-12 place-items-center rounded-md", tone]}>
      <Icon size={25} aria-hidden="true" />
    </div>
    <h3 class="mt-5 text-lg font-bold leading-tight text-slate-950 dark:text-white">{title}</h3>
    <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{description}</p>
  </article>
)}
