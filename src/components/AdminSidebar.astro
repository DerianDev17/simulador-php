---
import ChartColumn from "@lucide/astro/icons/chart-column";
import ClipboardList from "@lucide/astro/icons/clipboard-list";
import Grid2x2 from "@lucide/astro/icons/grid-2x2";
import House from "@lucide/astro/icons/house";
import ImportIcon from "@lucide/astro/icons/import";
import LogOut from "@lucide/astro/icons/log-out";
import Settings from "@lucide/astro/icons/settings";
import Trophy from "@lucide/astro/icons/trophy";
import Users from "@lucide/astro/icons/users";

type AdminSidebarActive =
  | "dashboard"
  | "categories"
  | "questions"
  | "simulations"
  | "users"
  | "import"
  | "reports"
  | "settings";

interface Props {
  active: AdminSidebarActive;
  csrfToken: string;
}

const { active, csrfToken } = Astro.props;

const items = [
  { id: "dashboard", label: "Panel", href: "/admin", icon: House },
  { id: "categories", label: "Categorias", href: "/admin/categorias", icon: Grid2x2 },
  { id: "questions", label: "Preguntas", href: "/admin/preguntas", icon: ClipboardList },
  { id: "simulations", label: "Simulacros", href: "/admin/simulacros", icon: Trophy },
  { id: "users", label: "Usuarios", href: "/admin/usuarios", icon: Users },
  { id: "import", label: "Importar", href: "/admin/importar", icon: ImportIcon },
  { id: "reports", label: "Reportes", href: "/admin/reportes", icon: ChartColumn },
  { id: "settings", label: "Configuracion", href: "/admin/configuracion", icon: Settings }
] as const;
---

<aside class="hidden min-h-[calc(100vh-3rem)] flex-col overflow-hidden rounded-lg border border-slate-200/80 bg-white/95 shadow-[0_18px_45px_rgba(15,23,42,0.07)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/90 dark:shadow-black/20 lg:flex">
  <a href="/admin" class="group flex items-center gap-3 border-b border-slate-200/80 px-4 py-4 dark:border-white/10">
    <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-orange-50 text-orange-600 ring-1 ring-orange-100 transition group-hover:bg-orange-100 dark:bg-orange-500/12 dark:text-orange-200 dark:ring-orange-400/20">
      <img src="/img/semilla-digital-logo.svg" alt="Semilla Digital" class="h-8 w-8 object-contain" />
    </span>
    <span class="min-w-0">
      <span class="block text-[10px] font-black uppercase leading-none tracking-normal text-orange-600 dark:text-orange-300">Administrador</span>
      <span class="mt-1 block truncate text-sm font-black leading-tight text-slate-950 dark:text-white">Semilla Digital</span>
    </span>
  </a>

  <nav class="flex-1 space-y-1 px-3 py-5" aria-label="Navegacion administrativa">
    {items.map((item) => {
      const Icon = item.icon;
      const isActive = active === item.id;
      return (
        <a
          href={item.href}
          aria-current={isActive ? "page" : undefined}
          class:list={[
            "focus-ring group relative flex min-h-11 items-center gap-3 rounded-md px-3 text-sm font-bold transition duration-200",
            isActive
              ? "bg-orange-50 text-orange-700 shadow-[inset_3px_0_0_#f97316] dark:bg-orange-500/15 dark:text-orange-200 dark:shadow-[inset_3px_0_0_#fb923c]"
              : "text-slate-700 hover:bg-slate-100 hover:text-slate-950 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white"
          ]}
        >
          <span
            class:list={[
              "grid h-7 w-7 shrink-0 place-items-center rounded-md transition",
              isActive
                ? "bg-white text-orange-600 shadow-sm dark:bg-orange-500/20 dark:text-orange-200"
                : "text-slate-500 group-hover:bg-white group-hover:text-orange-600 group-hover:shadow-sm dark:text-slate-400 dark:group-hover:bg-white/10 dark:group-hover:text-orange-200"
            ]}
          >
            <Icon size={17} stroke-width={2.25} aria-hidden="true" />
          </span>
          <span class="min-w-0 truncate">{item.label}</span>
        </a>
      );
    })}
  </nav>

  <form method="post" action="/admin/logout" class="border-t border-slate-200/80 p-3 dark:border-white/10">
    <input type="hidden" name="csrfToken" value={csrfToken} />
    <button class="focus-ring group flex min-h-11 w-full items-center gap-3 rounded-md px-3 text-sm font-bold text-slate-700 transition hover:bg-slate-100 hover:text-slate-950 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white">
      <span class="grid h-7 w-7 place-items-center rounded-md text-slate-500 transition group-hover:bg-white group-hover:text-orange-600 group-hover:shadow-sm dark:text-slate-400 dark:group-hover:bg-white/10 dark:group-hover:text-orange-200">
        <LogOut size={17} stroke-width={2.25} aria-hidden="true" />
      </span>
      <span>Cerrar sesion</span>
    </button>
  </form>
</aside>
